{
  "name": "quantum-safe-blockchain-guardrail",
  "version": "1.0.0",
  "description": "A quantum-safe blockchain guardrail system with post-quantum cryptography integration",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "build": "cd frontend && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:python": "cd backend && python -m pytest ../tests/*.py -v",
    "test:all": "npm run test && npm run test:python",
    "setup": "npm install && cd frontend && npm install && cd ../backend && pip install -r requirements.txt",
    "docker:build": "docker build -t quantum-safe-guardrail .",
    "docker:run": "docker run -p 3000:3000 -p 5000:5000 quantum-safe-guardrail",
    "docker:compose": "docker-compose up --build"
  },
  "keywords": [
    "blockchain",
    "quantum-safe",
    "post-quantum-cryptography",
    "ethereum",
    "security"
  ],
  "author": "Quantum-Safe Blockchain Team",
  "license": "MIT",
  "dependencies": {
    "ethers": "^6.8.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.14.2",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "@types/node": "^20.9.0"
  }
}
